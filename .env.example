# ─────────────────────────────────────────────
# Moodle Environment Variables
# Copy this to .env for local testing.
# In Coolify: set these in the Environment Variables tab — do NOT commit .env
# ─────────────────────────────────────────────

# Full URL of your Moodle site (must match your Coolify domain, with https://)
MOODLE_URL=https://moodle.yourdomain.com

# Database credentials
# MOODLE_DB_HOST is always "moodle-db" (the compose service name)
MOODLE_DB_NAME=moodle
MOODLE_DB_USER=moodle
MOODLE_DB_PASSWORD=ChangeMeToSomethingSecure
