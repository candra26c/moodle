# ─────────────────────────────────────────────
# Moodle Environment Variables
# Copy this to .env for local testing.
# In Coolify: set these in the Environment Variables tab — do NOT commit .env
# ─────────────────────────────────────────────

# Full public URL of your Moodle site (must match your Coolify domain, with https://)
MOODLE_URL=https://moodle.yourdomain.com

# Database credentials
# MOODLE_DB_HOST is always "moodle-db" (the compose service name — do not change)
MOODLE_DB_NAME=moodle
MOODLE_DB_USER=moodle
MOODLE_DB_PASSWORD=ChangeMeToSomethingSecure

# ─────────────────────────────────────────────
# Optional: LAN offline fallback
# When set, Moodle switches wwwroot based on the incoming hostname.
# Useful when the site should remain accessible on LAN if internet goes down.
# See docs/dual-access-setup.md for full setup (Pi-hole + BIND9).
#
# MOODLE_LOCAL_HOST — the hostname clients send when on LAN (no protocol)
# MOODLE_LOCAL_URL  — the URL Moodle uses when that hostname is matched
# ─────────────────────────────────────────────
MOODLE_LOCAL_HOST=moodle.yourdomain.com
MOODLE_LOCAL_URL=https://moodle.yourdomain.com
